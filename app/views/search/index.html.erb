<h1>Search through Parliament summaries</h1>

<%= form_with url: search_path, method: :get, local: true do %>
  <%= text_field_tag :q, @query, placeholder: "Search..." %>
  <%= submit_tag "Search" %>
<% end %>

<% if @error %>
  <p class="error"><%= @error %></p>
<% end %>

<% if @query.present? %>
  <h2>Results for "<%= h(@query) %>"</h2>

  <% if @results.present? %>
    <ul>
      <% @results["docs"].each do |item| %>
        <li><strong><%= item["speaker_name_s"] %></strong> - <%= item["start_dt"].to_date.strftime("%d.%m.%Y") %> </li>
        <td><%= item["text_t"] %></td>
      <% end %>
    </ul>
  <% else %>
    <p>No results found.</p>
  <% end %>
<% end %>